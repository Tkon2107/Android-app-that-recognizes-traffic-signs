<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F2F1"
    android:padding="30dp">

    <!-- App Logo -->
    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/g5_logo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:transitionName="app_logo_transition"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name" />

    <!-- Project Name -->
    <TextView
        android:id="@+id/projectNameTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/project_name"
        android:textColor="#00897B"
        android:textSize="20sp"
        android:fontFamily="@font/netflix_bold"
        android:layout_below="@id/appLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp" />

    <!-- CameraX PreviewView -->
    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="300dp"
        android:layout_height="330dp"
        android:layout_centerInParent="true">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Detection overlay for bounding boxes -->
        <com.trafficsignsclassification.DetectionOverlayView
            android:id="@+id/detectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- Captured Image Container with overlay -->
    <FrameLayout
        android:id="@+id/capturedContainer"
        android:layout_width="300dp"
        android:layout_height="330dp"
        android:layout_centerInParent="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/capturedImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/app_name" />

        <!-- Detection overlay for captured image -->
        <com.trafficsignsclassification.DetectionOverlayView
            android:id="@+id/capturedDetectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- Flash Toggle Button -->
    <ImageButton
        android:id="@+id/flashToggleButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/outline_flash_on_24"
        android:background="?android:attr/selectableItemBackground"
        android:layout_alignBottom="@id/cameraContainer"
        android:layout_alignEnd="@id/cameraContainer"
        android:layout_margin="8dp"
        android:contentDescription="@string/toggle_flashlight" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:visibility="gone"
        android:indeterminateTint="#00897B" />

    <!-- Class Text -->
    <TextView
        android:id="@+id/classTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/class_label"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:fontFamily="@font/netflix_bold"
        android:layout_above="@id/cameraContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp" />

    <!-- Probability Text -->
    <TextView
        android:id="@+id/probabilityTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/probability_label"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:fontFamily="@font/netflix_bold"
        android:layout_below="@id/cameraContainer"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <!-- Top Predictions (for captured mode) -->
    <TextView
        android:id="@+id/topPredictionsTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#283593"
        android:textSize="14sp"
        android:fontFamily="@font/netflix_regular"
        android:layout_below="@id/probabilityTextView"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:gravity="center" />

    <!-- Penalty Button (shown after capture) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/viewPenaltyButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.Button"
        android:text="@string/view_penalty"
        android:textAllCaps="false"
        android:fontFamily="@font/netflix_bold"
        android:textColor="@color/white"
        app:backgroundTint="#FF5722"
        app:cornerRadius="50dp"
        android:visibility="gone"
        android:layout_below="@id/probabilityTextView"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <!-- Permission Layout -->
    <LinearLayout
        android:id="@+id/permissionLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/permissionMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permission_message"
            android:textColor="#283593"
            android:fontFamily="@font/netflix_regular"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:height="60dp"
            android:textAllCaps="false"
            android:fontFamily="@font/netflix_bold"
            android:text="@string/open_settings"
            android:textColor="@color/white"
            app:backgroundTint="@color/iconColor"
            app:cornerRadius="50dp"
            app:rippleColor="@color/rippleColor"/>
    </LinearLayout>

    <!-- Bottom Control Buttons -->
    <LinearLayout
        android:id="@+id/controlButtonsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Retake Button (hidden by default) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/retakeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/retake_button"
            android:textAllCaps="false"
            android:fontFamily="@font/netflix_bold"
            android:textColor="@color/white"
            app:backgroundTint="#FF5722"
            app:cornerRadius="50dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone" />

        <!-- Capture Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/captureButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button"
            android:text="@string/capture_button"
            android:textAllCaps="false"
            android:fontFamily="@font/netflix_bold"
            android:textColor="@color/white"
            app:backgroundTint="#00897B"
            app:cornerRadius="50dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart" />
    </LinearLayout>

    <!-- Instruction Text -->
    <LinearLayout
        android:id="@+id/instructionLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_above="@id/controlButtonsLayout"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/infoIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/outline_info_24"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/info_icon"
            android:layout_gravity="center_vertical"/>

        <TextView
            android:id="@+id/instructionTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/instruction_text"
            android:textColor="#283593"
            android:fontFamily="@font/netflix_regular"
            android:textSize="14sp"/>
    </LinearLayout>
</RelativeLayout>
