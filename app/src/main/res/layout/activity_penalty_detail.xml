<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F2F1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/signNameTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên biển báo"
                    android:textColor="#00897B"
                    android:textSize="24sp"
                    android:fontFamily="@font/netflix_bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/severityTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="Mức độ: Trung bình"
                    android:textColor="#FF5722"
                    android:textSize="14sp"
                    android:fontFamily="@font/netflix_bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Violation Info -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hành vi vi phạm"
                    android:textColor="#283593"
                    android:textSize="16sp"
                    android:fontFamily="@font/netflix_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/violationNameTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mô tả vi phạm"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/netflix_regular" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fine for Cars -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFF3E0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mức phạt - Ô tô"
                    android:textColor="#E65100"
                    android:textSize="16sp"
                    android:fontFamily="@font/netflix_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/carFineTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="800.000 - 1.000.000 đồng"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/netflix_bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fine for Motorbikes -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E3F2FD">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mức phạt - Xe máy"
                    android:textColor="#1565C0"
                    android:textSize="16sp"
                    android:fontFamily="@font/netflix_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/motorbikeFineTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="400.000 - 600.000 đồng"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/netflix_bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Additional Penalty -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/additionalPenaltyCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hình phạt bổ sung"
                    android:textColor="#C62828"
                    android:textSize="16sp"
                    android:fontFamily="@font/netflix_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/additionalPenaltyTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tước GPLX 1-3 tháng"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/netflix_regular" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Legal Reference -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Căn cứ pháp lý"
                    android:textColor="#283593"
                    android:textSize="16sp"
                    android:fontFamily="@font/netflix_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/legalReferenceTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nghị định 100/2019/NĐ-CP"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/netflix_regular" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notes -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/notesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ghi chú"
                    android:textColor="#283593"
                    android:textSize="16sp"
                    android:fontFamily="@font/netflix_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/notesTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ghi chú thêm"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:fontFamily="@font/netflix_regular" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Last Updated -->
        <TextView
            android:id="@+id/lastUpdatedTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cập nhật: 15/01/2026"
            android:textColor="#757575"
            android:textSize="12sp"
            android:fontFamily="@font/netflix_regular"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Close Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đóng"
            android:textAllCaps="false"
            android:fontFamily="@font/netflix_bold"
            android:textColor="@color/white"
            app:backgroundTint="#00897B"
            app:cornerRadius="50dp"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
